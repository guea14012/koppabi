{
  "name": "koppabi", "version": "1.0.0",
  "description": "KOPPABI — Business Intelligence by KoppaZZZ",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc && vite build",
    "build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1", "react-dom": "^18.3.1",
    "framer-motion": "^11.0.20", "zustand": "^4.5.2",
    "lucide-react": "^0.376.0", "clsx": "^2.1.1",
    "electron-store": "^8.2.0", "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.0", "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "electron": "^29.4.0", "electron-builder": "^24.13.3",
    "vite-plugin-electron": "^0.28.4", "vite-plugin-electron-renderer": "^0.14.5",
    "@vitejs/plugin-react": "^4.2.1", "vite": "^5.2.8",
    "typescript": "^5.4.5", "@types/react": "^18.3.1", "@types/react-dom": "^18.3.0",
    "@types/node": "^20.12.7",
    "tailwindcss": "^3.4.3", "autoprefixer": "^10.4.19", "postcss": "^8.4.38",
    "concurrently": "^8.2.2", "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.koppazzz.koppabi", "productName": "KOPPABI",
    "directories": { "output": "release/${version}" },
    "files": ["dist/**/*", "dist-electron/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }], "icon": "assets/icon.ico" }
  }
}
